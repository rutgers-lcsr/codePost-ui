{
  "extends": ["tslint:recommended", "tslint-react", "tslint-config-prettier"],
  "linterOptions": {
    "exclude": [
      "config/**/*.js",
      "node_modules/**/*.ts",
      "coverage/lcov-report/*.js",
      "venv/**/*.ts"
    ]
  },
  "jsRules": {
    "object-literal-sort-keys": false //Disable for javascript
  }
}
