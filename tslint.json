{
  "extends": ["tslint:recommended", "tslint-react", "tslint-config-prettier", "tslint-config-airbnb"],
  "rulesDirectory": ["tslint-plugin-prettier"],
  "linterOptions": {
    "exclude": ["config/**/*.js", "node_modules/**/*.ts", "coverage/lcov-report/*.js", "venv/**/*.ts"]
  },
  "rules": {
    "max-line-length": [true, 120],
    "max-classes-per-file": [true, 1, "exclude-class-expressions"],
    "no-console": false,
    "no-else-after-return": false,
    "no-string-literal": false,
    "object-literal-sort-keys": false,
    "semicolon": [true, "always", "ignore-bound-class-methods"],
    "variable-name": [
      true,
      "check-format",
      "allow-leading-underscore",
      "allow-trailing-underscore",
      "allow-pascal-case"
    ],
    "import-name": false,
    "object-shorthand-properties-first": false,
    "jsx-boolean-value": ["never"],
    "align": [true, "parameters", "statements", "members", "elements"],
    "prefer-array-literal": [
      true,
      {
        "allow-type-parameters": true
      }
    ],
    "interface-over-type-literal": false
  },
  "jsRules": {
    "object-literal-sort-keys": false
  }
}
